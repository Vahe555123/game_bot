DEBUG=true
HOST=127.0.0.1
PORT=8000

DATABASE_URL=sqlite:///./products.db

# Пересборка FTS-индекса каталога при старте приложения (SQLite).
# true — не ждать пересборку при старте (экстренный подъём; поиск может быть неполным).
# false или не задавать — пересобрать при необходимости (рекомендуется; в новых версиях это быстро).
SQLITE_SKIP_FTS_REBUILD_ON_STARTUP=false

# Rebuild SQLite products from result.pkl on application startup.
# Usually keep this false; run `python main.py --rebuild-products` when you intentionally want to import result.pkl.
PRODUCTS_REBUILD_ON_STARTUP=false
PRODUCTS_REBUILD_ALWAYS=false
PRODUCTS_REBUILD_DELETE_STALE=true
PRODUCTS_REBUILD_ALLOW_SHRINK=false
PRODUCTS_REBUILD_MIN_REPLACE_RATIO=0.5
PRODUCTS_RESULT_CACHE_PATH=result.pkl
PRODUCTS_PROMO_CACHE_PATH=promo.pkl
PRODUCTS_REBUILD_BATCH_SIZE=1000
PRODUCTS_USE_CARDS_TABLE=true

# Денормализованный каталог product_cards пересобирается точечно после ручного парсинга.
# Включайте true только когда нужно принудительно пересобрать все карточки при старте.
PRODUCTS_CARDS_REBUILD_ON_STARTUP=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=
WEBAPP_URL=https://bot-game.duckdns.org/webapp
PUBLIC_APP_URL=https://gamebot2.duckdns.org
MANAGER_TELEGRAM_URL=https://t.me/your_manager_username

CORS_ALLOW_ALL=false
CORS_ORIGINS=https://gamebot2.duckdns.org,https://bot-game.duckdns.org

AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_COOKIE_NAME=site_session
AUTH_OAUTH_STATE_SECRET=replace-with-a-long-random-secret
AUTH_DEFAULT_REDIRECT_PATH=/profile

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_APP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="PlayStation Store"
SMTP_USE_TLS=true
SMTP_USE_SSL=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

ADMIN_TELEGRAM_IDS=
ADMIN_SECRET_KEY=replace-with-a-long-random-secret

# === ПРОКСИ ДЛЯ ПАРСЕРА ===
# true — все aiohttp-сессии парсера пойдут через прокси.
# false (или не задано) — без прокси, прямые запросы.
# На сервере с датацентровым IP включайте, если PS Store отдаёт 403 (AkamaiGHost Access Denied).
PARSER_USE_PROXY=false
# Список HTTP-прокси через запятую (предпочтительно).
# Парсер автоматически переключается между ними при банах (10 подряд 403).
# Формат каждого: http://user:pass@host:port
# SOCKS5 не поддерживается aiohttp напрямую — берите HTTP-вариант у провайдера.
PARSER_PROXY_LIST=
# Старый формат (1 прокси) — работает как fallback если PARSER_PROXY_LIST пуст.
PARSER_PROXY_URL=
# Тонкая настройка автосмены прокси (значения по умолчанию обычно ОК):
# PARSER_PROXY_BAN_THRESHOLD=10        # сколько подряд 403 = бан
# PARSER_PROXY_COOLDOWN_SECONDS=300    # сколько забаненный прокси отдыхает (сек)
